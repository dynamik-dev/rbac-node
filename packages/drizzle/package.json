{
  "name": "@rbac-node/drizzle",
  "version": "0.0.1",
  "description": "Drizzle driver for @rbac-node/core. Postgres, MySQL, SQLite.",
  "license": "MIT",
  "author": "Chris Arter <chris@arter.dev>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema/postgres": {
      "types": "./dist/schema/postgres.d.ts",
      "default": "./dist/schema/postgres.js"
    },
    "./schema/mysql": {
      "types": "./dist/schema/mysql.d.ts",
      "default": "./dist/schema/mysql.js"
    },
    "./schema/sqlite": {
      "types": "./dist/schema/sqlite.d.ts",
      "default": "./dist/schema/sqlite.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@rbac-node/core": "workspace:*"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.36"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
